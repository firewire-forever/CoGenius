# LLM API Configuration
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4

# PDF LLM Configuration (for PDF extraction module)
PDF_LLM_API_URL=https://api.openai.com/v1
PDF_LLM_API_KEY=your-api-key-here
PDF_LLM_MODEL=gpt-4

# Ansible Generation Configuration (Dify Agent)
ANSIBLE_GEN_URL=
ANSIBLE_GEN_KEY=

# VSDL Configuration
VSDL_SCRIPTS_DIR=data/vsdl_scripts
VSDLC_OUTPUT_DIR=data/vsdlc_output

# OpenStack Configuration (REQUIRED)
OPENSTACK_USER=
OPENSTACK_PASSWORD=
OPENSTACK_URL=
OPENSTACK_TENANT_NAME=vsdl
OPENSTACK_DOMAIN=Default

# SSH Key Paths (REQUIRED)
SSH_PUBKEY_PATH=/home/ubuntu/.ssh/id_rsa.pub
SSH_PRIVATE_KEY_PATH=/home/ubuntu/.ssh/id_rsa

# Jumphost (Bastion) Configuration for Ansible
JUMPHOST_HOST=
JUMPHOST_USER=
JUMPHOST_PORT=22
JUMPHOST_PASSWORD=

# PDF-RE Service URL
PDF_RE_SERVICE_URL=http://localhost:8000

# Solver Configuration (Python compiler uses built-in SMT)
SOLVER_PATH=tools/z3
SOLVER_ARGS=-smt2

# TTU Configuration
TTU_DEFAULT=10
TTU_STEP=5

# File Storage Configuration
CASE_CONTENT_DIR=data/case_content

# HuggingFace Offline Mode
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
UNSTRUCTURED_LOCAL_INFERENCE=1
HF_HOME=/home/appuser
HF_HUB_CACHE=/home/appuser/models